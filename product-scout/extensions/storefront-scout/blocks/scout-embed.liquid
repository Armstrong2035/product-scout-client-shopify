{% schema %}
{
  "name": "Product Scout",
  "target": "body",
  "stylesheet": "scout.css",
  "javascript": "scout.js",
  "settings": [
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display Mode",
      "options": [
        { "value": "floating", "label": "Floating Button" },
        { "value": "hijack", "label": "Native Search Hijack" }
      ],
      "default": "floating"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Scout"
    }
  ]
}
{% endschema %}

<div id="scout-app-container" 
     data-mode="{{ block.settings.display_mode }}">
  
  {% if block.settings.display_mode == 'floating' %}
    <!-- Floating Trigger -->
    <button id="scout-trigger" class="scout-trigger-btn" aria-label="Open AI Search">
      <span class="scout-icon">🔍</span>
      <span class="scout-label">{{ block.settings.button_label }}</span>
    </button>
  {% endif %}

  <!-- Search Overlay -->
  <div id="scout-overlay" class="scout-overlay hidden">
    <div class="scout-modal">
      <div class="scout-header">
        <div class="scout-search-wrapper">
          <input type="text" id="scout-input" placeholder="Ask Scout anything about our products..." autofocus>
          <button id="scout-close" class="scout-close-btn">&times;</button>
        </div>
      </div>
      <div id="scout-results" class="scout-results">
        <div class="scout-empty">
          <p>Try searching for features, colors, or uses.</p>
          <div class="scout-suggestions">
            <button class="scout-suggestion">"Something lightweight"</button>
            <button class="scout-suggestion">"Gift ideas for runners"</button>
          </div>
        </div>
      </div>
      
      <!-- Product Detail Drawer -->
      <div id="scout-detail-drawer" class="scout-detail-drawer hidden">
        <div class="scout-drawer-header">
           <button id="scout-drawer-close" class="scout-drawer-close-btn">&larr; Results</button>
           <div class="scout-drawer-nav">
             <button id="scout-prev-product" class="scout-nav-btn" title="Previous Product">&uarr;</button>
             <button id="scout-next-product" class="scout-nav-btn" title="Next Product">&darr;</button>
           </div>
        </div>
        <div id="scout-drawer-content" class="scout-drawer-content">
          <!-- Populated via JS -->
        </div>
      </div>
      <div class="scout-footer">
        Powered by AI Product Scout
      </div>
    </div>
  </div>
</div>
